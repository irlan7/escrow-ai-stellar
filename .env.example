# Domain untuk Escrow AI (frontend di /, API di /api/) — arahkan A record
# ke IP VPS ini sebelum menjalankan certbot
DOMAIN=escrow.quantumpaychain.org

# API key Cerebras (gratis) — dapatkan di https://cloud.ai.cerebras.ai/
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxx

# Opsional, default sudah gpt-oss-120b
# CEREBRAS_MODEL=gpt-oss-120b
