# Domain untuk frontend (client) — arahkan A record ke IP VPS ini dulu sebelum deploy
DOMAIN_CLIENT=escrow.quantumpaychain.org

# Domain untuk backend (server/API) — subdomain terpisah, juga arahkan A record ke IP VPS ini
DOMAIN_API=escrow-api.quantumpaychain.org

# API key Cerebras (gratis) — dapatkan di https://cloud.ai.cerebras.ai/
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxx

# Opsional, default sudah gpt-oss-120b
# CEREBRAS_MODEL=gpt-oss-120b
